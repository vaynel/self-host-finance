DATABASE_URL=postgresql://mandu:mandu@localhost:5435/finflow
JWT_SECRET=dev-secret-change-in-production

# JWT
JWT_SECRET=your-secret-key-at-least-32-characters-long
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=8000
ENV=development

# CORS (comma-separated for multiple origins)
# 프론트엔드 Origin: 8000(Vite), 5173(Vite 기본), 3000 등
CORS_ORIGIN=http://localhost:8000,http://localhost:8001,http://192.168.35.50:8000,http://127.0.0.1:8000,http://127.0.0.1:5173,,http://127.0.0.1:8001